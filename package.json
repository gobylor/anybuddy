{
  "name": "anybuddy-web",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:cli": "node scripts/test-cli-flow.mjs",
    "pack:cli": "npm pack --dry-run ./packages/cli",
    "release:cli:dry": "pnpm test && node packages/cli/bin/anybuddy.mjs --help && npm publish --dry-run ./packages/cli --access public",
    "release:cli": "npm run release:cli:dry && npm publish ./packages/cli --access public"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.0",
    "eslint": "^8",
    "eslint-config-next": "^14.2.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
